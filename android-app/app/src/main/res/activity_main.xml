<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0F19">

    <!-- 顶部导航栏 -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:background="#111827">

            <!-- AI头像 -->
            <FrameLayout
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:layout_marginEnd="12dp">
                
                <View
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="@drawable/ai_avatar_bg"/>
                    
                <ImageView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:layout_gravity="center"
                    android:src="@drawable/ic_robot"
                    android:contentDescription="AI Logo"/>
            </FrameLayout>

            <!-- 标题和状态 -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Hermes AI"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="#F9FAFB"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <View
                        android:id="@+id/vStatusDot"
                        android:layout_width="8dp"
                        android:layout_height="8dp"
                        android:background="@drawable/status_dot"/>

                    <TextView
                        android:id="@+id/tvStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="● 未连接"
                        android:textSize="12sp"
                        android:textColor="#6B7280"
                        android:layout_marginStart="6dp"/>
                </LinearLayout>
            </LinearLayout>

            <!-- 设置按钮 -->
            <ImageButton
                android:id="@+id/btnSettings"
                android:layout_width="44dp"
                android:layout_height="44dp"
                android:src="@android:drawable/ic_menu_preferences"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="设置"
                android:tint="#9CA3AF"/>
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- 聊天消息列表 -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvMessages"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="70dp"
        android:layout_marginBottom="70dp"
        android:padding="12dp"
        android:clipToPadding="false"
        android:background="#0B0F19"/>

    <!-- 思考过程面板 -->
    <LinearLayout
        android:id="@+id/llThinking"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#1F2937"
        android:padding="12dp"
        android:layout_margin="12dp"
        android:layout_marginTop="70dp"
        android:visibility="gone"
        android:elevation="4dp"
        android:rotationX="90">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💭 思考中..."
            android:textSize="12sp"
            android:textColor="#60A5FA"
            android:fontFamily="monospace"
            android:alpha="0.8"
            android:layout_marginBottom="6dp"/>

        <TextView
            android:id="@+id/tvThinking"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:textColor="#94A3B8"
            android:fontFamily="monospace"
            android:lineSpacingExtra="2dp"/>

        <ProgressBar
            android:id="@+id/pbLoading"
            style="?android:attr/progressBarStyleHorizontal"
            android:layout_width="match_parent"
            android:layout_height="3dp"
            android:layout_marginTop="8dp"
            android:progressTint="#3B82F6"
            android:indeterminate="true"
            android:indeterminateTint="#3B82F6"/>
    </LinearLayout>

    <!-- 底部输入区域 -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="#111827"
        android:padding="8dp"
        android:layout_gravity="bottom"
        android:elevation="8dp">

        <!-- 输入行 -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:padding="4dp">

            <EditText
                android:id="@+id/etInput"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:hint="输入消息..."
                android:textSize="16sp"
                android:textColor="#F9FAFB"
                android:textColorHint="#6B7280"
                android:background="@drawable/input_bg"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:maxLines="4"
                android:inputType="textAutoCorrect|textCapSentences"/>

            <!-- 语音按钮 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnMic"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@android:drawable/ic_btn_speak_now"
                app:fabSize="mini"
                app:tint="#FFFFFF"
                app:backgroundTint="#DC2626"
                app:elevation="2dp"/>

            <!-- 发送按钮 -->
            <com.google.android.material.floatingactionbutton.FloatingActionButton
                android:id="@+id/btnSend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="4dp"
                android:src="@android:drawable/ic_menu_send"
                app:fabSize="mini"
                app:tint="#FFFFFF"
                app:backgroundTint="#2563EB"
                app:elevation="2dp"/>
        </LinearLayout>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>

